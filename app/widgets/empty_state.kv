<EmptyState@MDBoxLayout>:
    id: empty_box
    orientation: 'vertical'
    adaptive_height: True
    size_hint_x: .85
    pos_hint: {"center_x": .5, "center_y": .5}
    spacing: dp(32)
    
    # Custom Properties
    title: ""
    description: ""
    # Use this to show/hide the button if needed (like 'Add First Entry')
    callback: None
    button_text: ""
    show_button: False

    # --- Custom Multicolored Graphic ---
    Widget:
        size_hint: None, None
        size: dp(180), dp(180)
        pos_hint: {"center_x": .5}
        canvas.before:
            # 1. Outer Halo
            Color:
                rgba: app.theme_cls.primaryColor[0], app.theme_cls.primaryColor[1], app.theme_cls.primaryColor[2], 0.05
            Ellipse:
                size: self.size
                pos: self.pos
            
            # 2. INNER LENS FILL
            Color:
                rgba: app.theme_cls.primaryColor[0], app.theme_cls.primaryColor[1], app.theme_cls.primaryColor[2], 0.15
            Ellipse:
                size: dp(76), dp(76)
                pos: (self.center_x - dp(50), self.center_y - dp(26))

            # 3. PRIMARY BORDERS
            Color:
                rgba: app.theme_cls.primaryColor
            Line: 
                circle: (self.center_x - dp(12), self.center_y + dp(12), dp(38))
                width: dp(4)
            Line: 
                points: [self.center_x + dp(18), self.center_y - dp(18), self.center_x + dp(55), self.center_y - dp(55)]
                width: dp(7)
                cap: 'round'
            
            # 4. GLASS SHINE
            Color:
                rgba: 1, 1, 1, 0.5
            Line:
                circle: (self.center_x - dp(28), self.center_y + dp(28), dp(10), 0, 95)
                width: dp(2.5)
                cap: 'round'

    MDBoxLayout:
        orientation: 'vertical'
        adaptive_height: True
        spacing: dp(10)
        
        MDLabel:
            id: empty_title
            text: root.title
            font_style: "Title"
            role: "medium"
            halign: "center"
            adaptive_height: True
            theme_text_color: "Primary"

        MDLabel:
            id: empty_desc
            text: root.description
            font_style: "Body"
            role: "small"
            halign: "center"
            adaptive_height: True
            theme_text_color: "Secondary"

    # Optional Action Button
    MDButton:
        style: "filled"
        pos_hint: {"center_x": .5}
        on_release: if root.callback: root.callback()
        opacity: 1 if root.show_button else 0
        disabled: not root.show_button
        MDButtonText:
            text: root.button_text